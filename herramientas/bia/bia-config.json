  "frameworks": {
    "iso22301": {
      "id": "iso22301",
      "nombre": "ISO 22301:2019",
      "nombre_corto": "ISO 22301",
      "tag": "BIA · BCP · DRP · ISO 22301",
      "color": "fw-iso22301",
      "icono": "📋",
      "controles": "Cláusulas 8.2.2 (BIA), 8.3 (estrategias y soluciones) y 8.4 (planes y procedimientos)",
      "explicacion": "ISO 22301 utiliza el BIA para identificar prioridades, impactos y requisitos de recuperación. RTO y RPO deben derivarse del contexto y validarse con negocio; la herramienta solo los documenta."
    },
    "iso27001": {
      "id": "iso27001",
      "nombre": "ISO 27001:2022",
      "nombre_corto": "ISO 27001",
      "tag": "BIA · Continuidad SI · ISO 27001",
      "color": "fw-iso27001",
      "icono": "🔐",
      "controles": "Controles A.5.29 (Continuidad de SI) y A.5.30 (Preparación TIC para continuidad)",
      "explicacion": "Los controles A.5.29 y A.5.30 requieren continuidad de la seguridad de la información y preparación TIC. Un BIA ayuda a justificar prioridades y objetivos, pero ISO 27001 no impone esta plantilla ni umbrales universales."
    },
    "ens": {
      "id": "ens",
      "nombre": "ENS RD 311/2022",
      "nombre_corto": "ENS",
      "tag": "BIA · Continuidad · ENS RD 311/2022",
      "color": "fw-ens",
      "icono": "🏛",
      "controles": "Medidas op.cont.1 (análisis de impacto), op.cont.2 (plan de continuidad) y op.cont.3 (pruebas periódicas)",
      "explicacion": "El ENS estructura la continuidad en la familia op.cont. El análisis de impacto, el plan y sus pruebas deben relacionarse con los servicios y sistemas dentro del alcance."
    },
    "nis2": {
      "id": "nis2",
      "nombre": "Directiva NIS2 (UE) 2022/2555",
      "nombre_corto": "NIS2",
      "tag": "BIA · Continuidad · NIS2 · Art. 21",
      "color": "fw-nis2",
      "icono": "🇪🇺",
      "controles": "Artículo 21.2(c) — Continuidad de negocio y gestión de crisis",
      "explicacion": "El artículo 21.2(c) obliga a continuidad de negocio y gestión de crisis. El BIA es la evidencia técnica de que has identificado las funciones esenciales y sus tiempos de recuperación."
    },
    "dora": {
      "id": "dora",
      "nombre": "DORA (UE) 2022/2554",
      "nombre_corto": "DORA",
      "tag": "BIA · DORA · ICT Riesgo · Servicios Críticos",
      "color": "fw-dora",
      "icono": "🏦",
      "controles": "Art. 11.5 (BIA dentro de la política de continuidad TIC) y Art. 12 (copias, restauración y recuperación)",
      "explicacion": "DORA exige a las entidades financieras analizar la exposición e impacto de disrupciones TIC, especialmente sobre funciones críticas o importantes, y mantener capacidades de respuesta, recuperación, copia y restauración."
    },
    "iso42001": {
      "id": "iso42001",
      "nombre": "ISO 42001:2023 (IA)",
      "nombre_corto": "ISO 42001",
      "tag": "BIA · IA · ISO 42001 · Sistemas Autónomos",
      "color": "fw-iso42001",
      "icono": "🤖",
      "controles": "Cláusula 8.4 (evaluación de impacto de sistemas de IA) y continuidad definida por el sistema de gestión",
      "explicacion": "ISO/IEC 42001 sitúa la evaluación de impacto del sistema de IA en la cláusula 8.4. Para continuidad, además de disponibilidad, conviene validar supervisión humana, dependencias, datos, deriva y comportamiento seguro tras la recuperación."
    }
  },
